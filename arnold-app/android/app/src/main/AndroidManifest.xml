<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|locale|smallestScreenSize|screenLayout|uiMode|navigation|density"
            android:name=".MainActivity"
            android:label="@string/title_activity_main"
            android:theme="@style/AppTheme.NoActionBarLaunch"
            android:launchMode="singleTask"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- FileProvider is auto-registered by @capacitor/filesystem and
             @capacitor/share via manifest merger. The previous declaration
             pointed at a non-existent @xml/file_paths resource (leftover from
             a prior plugin) and blocked Gradle's manifest merge once two
             plugins with the same authority were added. -->

        <!-- Health Connect permissions rationale activity -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:targetActivity=".MainActivity"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>
    </application>

    <!-- Permissions -->

    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Health Connect permissions — Arnold is a one-way reader (see
         src/core/hc-sync.js header policy). The set below matches exactly the
         streams syncAll() consumes: sleep, weight, heart rate, and the daily
         energy trio (steps + active + total calories). Anything not in this
         list is intentionally NOT requested:
           READ_EXERCISE   — FIT uploads via Cloud Sync are authoritative.
           READ_NUTRITION  — Cronometer live pull is authoritative.
           READ_HYDRATION  — no consumer.
           READ_DISTANCE   — derived from Steps; no direct consumer.
         WRITE_* permissions never declared — Arnold never writes to HC. -->
    <uses-permission android:name="android.permission.health.READ_SLEEP" />
    <uses-permission android:name="android.permission.health.READ_WEIGHT" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_TOTAL_CALORIES_BURNED" />

    <!-- Declare Health Connect data types used -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>
</manifest>
